#!/usr/bin/env bash

# Find the current file directory, supporting symlinks
WEX_DIR_CLI="$(realpath "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")")/"
WEX_DIR_ROOT=$(realpath "${WEX_DIR_CLI}../")/

# shellcheck disable=SC1090
. "${WEX_DIR_ROOT}.wex/.env"

# Use the venv pip explicitly so this works whether or not the venv is activated
VENV_PIP="${WEX_DIR_ROOT}.venv/bin/pip"

# Install every local dev package as editable
for dir in $(ls -d "${LOCAL_PIP_PACKAGES_PATH}"*/); do
    "${VENV_PIP}" install -q -e "${dir}"
done